PORT=5179
DATA_DIR=./data

# Google Cloud OAuth (Web client). Redirect must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:5179/oauth/callback

# After OAuth, browser returns here (use 5179 when running npm start after build)
FRONTEND_ORIGIN=http://127.0.0.1:5179

# Optional Gmail sync tuning (inbox only; max threads to scan per check)
GMAIL_SYNC_MAX=50

# Optional Claude AI (job URL import, email parsing, Gmail suggestions)
ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=   # alias for ANTHROPIC_API_KEY
# CLAUDE_MODEL=claude-haiku-4-5-20251001
