PORT=5179
DATA_DIR=./data

# Google Cloud OAuth (Web or Desktop client). Redirect must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:5179/oauth/callback

# After OAuth, browser is sent here (Vite dev default). For production single-server,
# set to the same origin as the API, e.g. http://127.0.0.1:5179
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Optional Gmail sync tuning
GMAIL_SYNC_DAYS=30
GMAIL_SYNC_MAX=50
